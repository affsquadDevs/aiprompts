# ---------------------------------------------------------------------------
# PromptVault — environment variables
# Copy this file to `.env.local` (dev) or set these in your host (prod).
# ---------------------------------------------------------------------------

# REQUIRED IN PRODUCTION. Canonical site origin, used for canonical URLs, the
# sitemap, robots.txt, OpenGraph/Twitter cards and JSON-LD. No trailing slash.
# Until this points at your real domain, SEO metadata will be wrong.
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# --- Ads --------------------------------------------------------------------
# The site is fully static & ad-supported by Google AdSense. The publisher id
# ships with a built-in default in src/lib/ads.ts, so the AdSense loader and
# /ads.txt work out of the box. Override the publisher id here only if needed.
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
#
# Two ways to show ads:
#   1. Auto ads  — enable in the AdSense console; no slot ids required. Manual
#      <AdSlot> areas render nothing and Google places ads automatically.
#   2. Manual units — set the per-placement slot ids below to render fixed,
#      labelled ad units in the <AdSlot> positions.
# NEXT_PUBLIC_AD_SLOT_TOP=
# NEXT_PUBLIC_AD_SLOT_MID=
# NEXT_PUBLIC_AD_SLOT_LIST=
# NEXT_PUBLIC_AD_SLOT_DETAIL=
# NEXT_PUBLIC_AD_SLOT_CATEGORIES=  # categories INDEX page
# NEXT_PUBLIC_AD_SLOT_CATEGORY_DETAIL=  # a single category page
# NEXT_PUBLIC_AD_SLOT_ABOUT=
#
# REQUIRED for EEA/UK/CH: Google's EU User Consent Policy requires a
# Google-certified CMP (IAB TCF v2.2). Enable one in the AdSense console
# (Privacy & messaging → GDPR message / Funding Choices). Consent Mode v2
# defaults are pre-wired (denied for EEA/UK/CH before the ad loader). The
# on-site consent banner is only a FALLBACK notice: it auto-hides when a
# certified CMP is present, so the CMP governs consent in regulated regions.

# --- Contact ----------------------------------------------------------------
# Public contact / privacy / takedown email shown on the Contact & Privacy
# pages. Defaults to hello@prompts-vault.app.
# NEXT_PUBLIC_CONTACT_EMAIL=hello@yourdomain.com
